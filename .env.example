# Public Hugging Face Dataset release. Pin this to the 40-character release commit.
OPENBIOSCIENCE_ENV_REPOSITORY=<hugging-face-namespace>/openbioscience-environments
OPENBIOSCIENCE_ENV_REVISION=<replace-with-40-character-commit-sha>
OPENBIOSCIENCE_ENVIRONMENT=sc-py-singlecell

# Optional installed runtime root. Layout: <root>/environments/official/<environment-name>/
# OPENBIOSCIENCE_ENV_ROOT=/path/to/OpenBioScience/runtime
# OPENBIOSCIENCE_WORKSPACE_ROOT=/path/to/OpenBioScience
# OPENBIOSCIENCE_SKILL_ROOTS=/path/to/OpenBioScience/resources/skills
# OPENBIOSCIENCE_BIO_RESOURCE_ROOT=/path/to/OpenBioScience/resources/bio
# OPENBIOSCIENCE_GENE_SET_ROOT=/path/to/OpenBioScience/resources/bio/gene_sets
# OPENBIOSCIENCE_MARKER_ROOT=/path/to/OpenBioScience/resources/bio/markers
# OPENBIOSCIENCE_MSIGDB_ROOT=/path/to/OpenBioScience/resources/bio/gene_sets/msigdb
# Optional host-side resources/bio mount for compose.bio-resources.yaml.
# OPENBIOSCIENCE_BIO_RESOURCE_ROOT_HOST=/path/to/OpenBioScience/resources/bio

# Optional server-side agent runtime overlay. Required only when using
# compose.server-agents.yaml for remote WebUI deployments.
# OPENBIOSCIENCE_UID=1000
# OPENBIOSCIENCE_GID=1000
# OPENBIOSCIENCE_AGENT_NODE_ROOT=/path/to/node-runtime
# OPENBIOSCIENCE_AGENT_HOME=/path/to/writable-agent-home
# OPENBIOSCIENCE_CODEX_HOME=/path/to/codex-home
# OPENBIOSCIENCE_CLAUDE_HOME=/path/to/claude-home
# OPENBIOSCIENCE_SERVER_WORKSPACE_ROOT=/path/to/server/workspace

# Optional for rate-limited or gated repositories. Do not commit a real token.
# HF_TOKEN=
